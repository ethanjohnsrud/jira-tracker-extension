{
  "name": "Jira_Tracker",
  "displayName": "Jira Tracker",
  "version": "2.0",
  "description": "Automatically bookmark Jira tickets and link to AGO plan; including systematic environment navigation to aid development.",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "typecheck": "tsc --noEmit"
  },
  "author": "ethanjohnsrud",
  "license": "ISC",
  "dependencies": {
    "@heroui/react": "^3.0.2",
    "@heroui/styles": "^3.0.2",
    "@internationalized/date": "^3.12.0",
    "@tailwindcss/postcss": "4",
    "autoprefixer": "^10.4.20",
    "buffer": "^6.0.3",
    "date-fns": "^4.1.0",
    "lucide-react": "^1.7.0",
    "postcss": "^8.5.0",
    "postcss-preset-env": "^10.1.4",
    "prop-types": "^15.8.1",
    "react": "^19.2.4",
    "react-custom-checkbox": "^3.2.0",
    "react-dom": "^19.2.4",
    "react-flags-select": "^2.1.2",
    "react-select-search": "^3.0.9",
    "tailwindcss": "^4.2.2",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.4.0",
    "@eslint/js": "^9.39.4",
    "@types/chrome": "^0.1.24",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "debug": "^4.4.3",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "sass": "^1.49.7",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.2",
